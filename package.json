{
  "name": "stremio-enterprise-subtitles",
  "version": "1.7.6",
  "type": "module",
  "private": true,
  "description": "Fast Stremio Arabic subtitle add-on with server-side encoding normalization, smart filtering, and optional DeepSeek fallback.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "start:cluster": "node src/cluster.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-test-module-mocks --test src/tests/*.test.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "undici": "^8.5.0"
  }
}
